---
import ProjectPage from "@/components/ProjectPage.astro"
import { getProjectSlug } from "@/i18n/utils"
import Layout from "@/layouts/Layout.astro"
import { getProjectMetaDescription } from "@/lib/utils"
import { getCollection, render } from "astro:content"

export async function getStaticPaths() {
  const esProjects = await getCollection("projects", ({ id }) =>
    id.startsWith("es/")
  )

  return esProjects.map((project) => {
    const slug = getProjectSlug(project.id)

    return {
      params: { slug },
      props: { project },
    }
  })
}

const { project } = Astro.props
const { Content } = await render(project)

const pageTitle = `${project.data.title} - Franklin Martinez`
const pageDescription = getProjectMetaDescription(project.data.description)

const pageImage = project.data.image

const lang = "es"
---

<Layout
  title={pageTitle}
  description={pageDescription}
  image={{
    url: pageImage.src,
    alt: `Captura de pantalla de ${project.data.title}`,
  }}
>
  <ProjectPage project={project} lang={lang}>
    <Fragment slot="content">
      <Content />
    </Fragment>
  </ProjectPage>
</Layout>
