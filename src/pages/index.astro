---
import avatarImage from "@/assets/avatar.webp"
import HomePage from "@/components/HomePage.astro"
import Layout from "@/layouts/Layout.astro"
---

<Layout
  title='Franklin "franklinmdev" Martinez – Full-Stack AI Engineer'
  description="Portfolio of Franklin Martinez (franklinmdev), a Full-Stack AI Engineer specializing in React, Next.js, Node.js, .NET, and AI-powered development workflows."
  image={{
    url: avatarImage.src,
    alt: "Franklin Martinez - Full-Stack AI Engineer Profile Picture",
  }}
>
  <script is:inline>
    // Client-side language preference redirect. Static hosting has no server,
    // so language detection runs in the browser: an explicit choice in
    // localStorage wins, otherwise fall back to the browser language. Only
    // the bare "/" redirects, mirroring the previous default-locale behaviour.
    ;(function () {
      try {
        let choice = localStorage.getItem("preferred-lang")
        if (!choice) {
          choice = (navigator.language || "en").toLowerCase().slice(0, 2)
        }
        if (choice === "es") {
          window.location.replace("/es/")
        }
      } catch {
        /* localStorage unavailable: stay on the default locale */
      }
    })()
  </script>
  <HomePage lang="en" />
</Layout>
