---
import avatarImage from "@/assets/avatar.webp"
import HomePage from "@/components/HomePage.astro"
import Layout from "@/layouts/Layout.astro"
---

<Layout
  title='Franklin "franklinmdev" Martinez – Full-Stack Engineer'
  description="Franklin Martinez (franklinmdev) is a full-stack engineer building tax and compliance software for the Dominican market, end to end from the database to the screen."
  image={{
    url: avatarImage.src,
    alt: "Franklin Martinez - Full-Stack Engineer profile picture",
  }}
>
  <script is:inline slot="head">
    // Language redirect. Runs in <head> before the body paints. An explicit
    // choice in localStorage wins; otherwise fall back to the browser language.
    // Only the bare "/" redirects; the query string and hash are preserved.
    ;(function () {
      try {
        let choice = localStorage.getItem("preferred-lang")
        if (!choice) {
          choice = (navigator.language || "en").toLowerCase().slice(0, 2)
        }
        if (choice === "es") {
          const target = "/es/" + window.location.search + window.location.hash
          window.location.replace(target)
        }
      } catch {
        /* localStorage unavailable: stay on the default locale */
      }
    })()
  </script>
  <HomePage lang="en" />
</Layout>
