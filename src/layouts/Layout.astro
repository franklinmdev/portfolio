---
import avatarImage from "@/assets/avatar.webp"
import Footer from "@/components/Footer.astro"
import Header from "@/components/Header.astro"
import WebMCP from "@/components/react/WebMCP"
import { getLangFromUrl } from "@/i18n/utils"
import { removeLocalePrefix } from "@/i18n/utils"
import "@/styles/global.css"
import { ClientRouter } from "astro:transitions"

export interface Props {
  title: string
  description?: string
  publishDate?: string
  author?: string
  image?: {
    url: string
    alt: string
  }
}

const { title, description, publishDate, image } = Astro.props
const lang = getLangFromUrl(Astro.url)

const ogImageUrl = image?.url
  ? new URL(image.url, Astro.site)
  : new URL(avatarImage.src, Astro.site)

// hreflang alternates: strip any active locale prefix, then rebuild the
// en/es/x-default URLs from a single normalised path so the trailing slash
// is consistent across both language versions.
const cleanPath = removeLocalePrefix(Astro.url.pathname)
const normalizedPath = cleanPath.endsWith("/") ? cleanPath : `${cleanPath}/`
const enHref = new URL(normalizedPath, Astro.site)
const esHref = new URL(`/es${normalizedPath}`, Astro.site)
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    {
      /* No-flash theme: explicit choice wins, else the OS preference. Runs
        before paint and re-runs after each view transition swap. */
    }
    <script is:inline>
      ;(() => {
        const apply = () => {
          let saved = null
          try {
            saved = localStorage.getItem("theme")
          } catch {}
          const dark = saved
            ? saved === "dark"
            : window.matchMedia("(prefers-color-scheme: dark)").matches
          document.documentElement.classList.toggle("dark", dark)
          const meta = document.querySelector('meta[name="theme-color"]')
          if (meta) meta.setAttribute("content", dark ? "#0c0f16" : "#f3f1ec")
        }
        apply()
        document.addEventListener("astro:after-swap", apply)
      })()
    </script>
    <meta
      name="description"
      content={description ||
        "Franklin Martinez - Software Engineer and Web Developer Portfolio"}
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <slot name="head" />

    <!-- DNS prefetch for external domains -->
    <link rel="dns-prefetch" href="//github.com" />
    <link rel="dns-prefetch" href="//linkedin.com" />
    <link rel="dns-prefetch" href="//x.com" />

    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

    <!-- Optimized favicon set with proper sizes -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.png" sizes="192x192" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Enhanced SEO & PWA Meta -->
    {/* Single dynamic theme-color; the inline script keeps it in sync. */}
    <meta name="theme-color" content="#0c0f16" />
    <meta name="color-scheme" content="dark light" />
    <meta name="robots" content="index,follow" />
    <meta
      name="googlebot"
      content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1"
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:site_name" content="Franklin Martinez Portfolio" />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />

    <!-- hreflang alternate links -->
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="es" href={esHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />

    <!-- Standard OG/Twitter tags -->
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImageUrl} />
    <meta
      property="og:image:alt"
      content={image?.alt || "Franklin Martinez - Software Engineer Portfolio"}
    />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    {
      publishDate && (
        <meta property="article:published_time" content={publishDate} />
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@franklinmdev" />
    <meta name="twitter:image" content={ogImageUrl} />
    <!-- Complete Twitter card metadata -->
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:site" content="@franklinmdev" />
    <meta
      name="twitter:url"
      content={new URL(Astro.url.pathname, Astro.site)}
    />
    <meta
      name="twitter:domain"
      content={new URL(Astro.url.pathname, Astro.site).hostname}
    />

    <!-- Keywords for extra SEO relevance -->
    <meta
      name="keywords"
      content="franklinmdev, Franklin Martinez, software engineer, web developer, React, Astro, Next.js, TypeScript, Tailwind CSS"
    />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Structured data for better SEO -->
    {
      /* eslint-disable astro/no-set-html-directive -- JSON-LD payload is a static, trusted JSON.stringify, not user input */
    }
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Franklin Martinez",
        alternateName: "franklinmdev",
        description:
          "Software engineer specialising in React, Astro & TypeScript.",
        image: new URL(avatarImage.src, Astro.site),
        jobTitle: "Software Engineer & Web Developer",
        worksFor: {
          "@type": "Organization",
          name: "Nubeteck S.R.L.",
        },
        alumniOf: {
          "@type": "CollegeOrUniversity",
          name: "Universidad Central del Este",
          url: "https://www.uce.edu.do/",
        },
        email: "mailto:franklinmdev@hotmail.com",
        address: {
          "@type": "PostalAddress",
          addressLocality: "Santiago de los Caballeros",
          addressCountry: "DO",
        },
        knowsAbout: [
          "React",
          "Next.js",
          "Astro",
          "TypeScript",
          "Tailwind CSS",
          "Full-stack Development",
        ],
        url: "https://franklinmdev.me",
        sameAs: [
          "https://github.com/franklinmdev",
          "https://www.linkedin.com/in/franklin-martinez-0a697a253/",
          "https://x.com/franklinmdev",
        ],
      })}
    />
    {/* eslint-enable astro/no-set-html-directive */}

    <ClientRouter fallback="swap" />
  </head>
  <body class="antialiased">
    <Header />
    <slot />
    <Footer />
    <WebMCP client:idle />
  </body>
</html>
