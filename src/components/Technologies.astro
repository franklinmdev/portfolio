---
import { createTranslations, getLangFromUrl } from "@/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = createTranslations(lang)

// The differentiator leads: how the work gets done with AI. The stack below
// is baseline. Practice keys resolve to practice.items.<key>.{title,body}.
const practices = ["prd", "quality", "models"] as const

interface TechGroup {
  readonly labelKey: string
  readonly items: readonly string[]
}

// Grouped by competency rather than a flat tag wall. Tech names are product
// names — not translated. Group labels come from i18n.
const techGroups: readonly TechGroup[] = [
  {
    labelKey: "tech.groups.languages",
    items: ["TypeScript", "JavaScript", "C#", "Python", "SQL"],
  },
  {
    labelKey: "tech.groups.frontend",
    items: ["React", "Next.js", "Astro", "Tailwind CSS", "shadcn/ui"],
  },
  {
    labelKey: "tech.groups.backend",
    items: [
      "Node.js",
      "NestJS",
      "ASP.NET Core",
      "PostgreSQL",
      "SQL Server",
      "Prisma",
      "Entity Framework",
      "REST APIs",
    ],
  },
  {
    labelKey: "tech.groups.workflow",
    items: ["Jest", "Playwright", "CI/CD", "Vercel", "Claude Code"],
  },
] as const
---

<section id="technologies" class="scroll-mt-24">
  <span class="module-label">{t("hud.modules.tech")}</span>
  <h2 class="module-title text-foreground mt-3 mb-4">
    {t("practice.title")}
  </h2>
  <p class="text-muted-foreground mb-10 max-w-3xl leading-relaxed">
    {t("practice.intro")}
  </p>

  <div class="mb-12 max-w-3xl space-y-7">
    {
      practices.map((key, index) => (
        <div class="flex gap-4">
          <span class="text-muted-foreground pt-1 font-mono text-xs font-medium tabular-nums">
            {`0${index + 1}`}
          </span>
          <div>
            <h3 class="text-foreground mb-1 text-base font-semibold">
              {t(`practice.items.${key}.title`)}
            </h3>
            <p class="text-muted-foreground leading-relaxed">
              {t(`practice.items.${key}.body`)}
            </p>
          </div>
        </div>
      ))
    }
  </div>

  <hr class="border-border mb-8" />

  <p
    class="text-foreground mb-6 font-mono text-xs font-semibold tracking-wide uppercase"
  >
    {t("sections.tech_title")}
  </p>
  <div class="max-w-5xl space-y-6">
    {
      techGroups.map((group) => (
        <div>
          <p class="text-muted-foreground mb-3 font-mono text-xs font-medium tracking-wide uppercase">
            {t(group.labelKey)}
          </p>
          <div class="flex flex-wrap items-center gap-2.5">
            {group.items.map((tech) => (
              <span class="tech-tag">{tech}</span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
