---
import SocialLinks from "@/components/SocialLinks.astro"

export interface Props {
  t: (key: string) => string
}

const { t } = Astro.props
---

<!-- Sticky hero column -->
<div
  id="home"
  class="pt-24 pb-16 xl:sticky xl:top-0 xl:flex xl:max-h-screen xl:w-2/5 xl:flex-col xl:justify-between xl:py-28 2xl:w-[38%]"
>
  <div class="space-y-10">
    <!-- Identity -->
    <div>
      <span
        class="hero-headline text-muted-foreground mb-5 block font-mono text-[0.6875rem] font-semibold tracking-[0.16em] uppercase"
      >
        {t("hud.hero.id")}
      </span>
      <h1
        class="hero-headline text-foreground mb-4 text-4xl font-semibold sm:text-5xl lg:text-6xl xl:text-5xl"
      >
        Franklin <span class="sr-only">"franklinmdev"</span> Martinez
      </h1>
      <p
        class="hero-subtitle text-muted-foreground mb-8 font-mono text-sm font-medium tracking-wide sm:text-base"
      >
        {t("hero.subtitle")}
      </p>

      <!-- The one real large-type statement — his actual proof. -->
      <p
        class="hero-headline text-foreground measure text-xl leading-snug font-medium text-balance sm:text-2xl xl:text-xl 2xl:text-2xl"
      >
        {t("hero.statement")}
      </p>
    </div>

    <div
      class="hero-about text-muted-foreground measure space-y-4 text-base leading-relaxed"
    >
      <p>{t("hero.about.p1")}</p>
      <p>{t("hero.about.p2")}</p>
    </div>
  </div>

  <!-- Social links -->
  <SocialLinks t={t} />
</div>
