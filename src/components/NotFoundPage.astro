---
import { Image } from "astro:assets"
import errorImage from "@/assets/404.png"
import { House, Archive, ArrowLeft } from "@lucide/astro"
import { createTranslations, type Language } from "@/i18n/utils"

export interface Props {
  lang: Language
}

const { lang } = Astro.props
const t = createTranslations(lang)
---

<main
  class="flex min-h-screen items-center justify-center px-4 py-8 pt-20 sm:py-16 sm:pt-24"
>
  <div class="mx-auto max-w-xl text-center">
    <div class="mb-6 sm:mb-8">
      <Image
        src={errorImage}
        alt={t("error.404.image_alt")}
        class="mx-auto h-auto w-full max-w-48 object-contain opacity-90 sm:max-w-64 md:max-w-80"
        width="320"
        height="320"
      />
    </div>

    <div class="space-y-4 sm:space-y-6">
      <h1
        class="text-foreground text-2xl leading-tight font-semibold sm:text-4xl sm:leading-tight lg:text-5xl lg:leading-tight"
      >
        {t("error.404.heading")}
      </h1>

      <p
        class="text-muted-foreground mx-auto max-w-lg text-base leading-relaxed sm:text-lg"
      >
        {t("error.404.description")}
      </p>

      <div
        class="panel mx-auto mt-6 max-w-sm p-4 text-left sm:mt-8 sm:max-w-md sm:p-6"
      >
        <h3
          class="text-foreground mb-2 font-mono text-xs font-semibold tracking-wide uppercase sm:mb-3 sm:text-sm"
        >
          {t("error.404.reasons.title")}
        </h3>
        <ul
          class="text-muted-foreground space-y-1.5 text-xs sm:space-y-2 sm:text-sm"
        >
          <li class="flex items-center gap-2">
            <span class="text-muted-foreground/70">&gt;</span>
            {t("error.404.reasons.typo")}
          </li>
          <li class="flex items-center gap-2">
            <span class="text-muted-foreground/70">&gt;</span>
            {t("error.404.reasons.moved")}
          </li>
          <li class="flex items-center gap-2">
            <span class="text-muted-foreground/70">&gt;</span>
            {t("error.404.reasons.outdated")}
          </li>
        </ul>
      </div>

      <div
        class="mt-6 flex flex-col items-center justify-center gap-3 sm:mt-8 sm:flex-row sm:gap-4"
      >
        <a
          href={lang === "en" ? "/" : `/${lang}/`}
          class="group bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-9 w-full cursor-pointer items-center justify-center gap-2 rounded-sm px-4 py-2 font-mono text-sm font-medium tracking-wide uppercase transition-all duration-200 sm:w-auto"
        >
          <House
            class="size-4 transition-transform group-hover:-translate-x-1"
          />
          {t("error.404.actions.home")}
        </a>

        <a
          href={lang === "en" ? "/#projects" : `/${lang}/#projects`}
          class="group border-border bg-background text-foreground hover:border-primary/50 hover:text-primary inline-flex h-9 w-full cursor-pointer items-center justify-center gap-2 rounded-sm border px-4 py-2 font-mono text-sm font-medium tracking-wide uppercase transition-all duration-200 sm:w-auto"
        >
          <Archive class="size-4" />
          {t("error.404.actions.projects")}
        </a>

        <button
          onclick="history.back()"
          class="group text-muted-foreground hover:text-primary inline-flex h-9 w-full cursor-pointer items-center justify-center gap-2 rounded-sm px-4 py-2 font-mono text-sm font-medium tracking-wide uppercase transition-colors duration-200 sm:w-auto"
        >
          <ArrowLeft
            class="size-4 transition-transform group-hover:-translate-x-1"
          />
          {t("error.404.actions.previous")}
        </button>
      </div>
    </div>
  </div>
</main>
