---
import { getTranslationFromUrl } from "@/i18n/utils"

const t = getTranslationFromUrl(Astro.url)
---

<footer class="border-border mt-20 border-t px-4 pt-8 pb-10 sm:px-6 lg:px-8">
  <p
    class="text-muted-foreground flex items-center justify-center gap-2 text-center font-mono text-xs tracking-wide"
  >
    <span class="text-muted-foreground/60 select-none">//</span>
    {t("footer.credits")}
  </p>
</footer>
