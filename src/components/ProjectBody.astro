---
import type enTranslations from "@/i18n/en.json"
import type { CollectionEntry } from "astro:content"
export interface Props {
  project: CollectionEntry<"projects">
  t: typeof enTranslations.projects
}
const { project, t } = Astro.props
---

<section>
  <h2 class="text-foreground mb-4 text-2xl font-semibold">{t.overview}</h2>
  <div class="text-muted-foreground space-y-4 leading-relaxed">
    {
      Array.isArray(project.data.description) ? (
        project.data.description.map((p: string) => <p>{p}</p>)
      ) : (
        <p>{project.data.description}</p>
      )
    }
  </div>
</section>

<section>
  <div class="prose max-w-none">
    <slot name="content" />
  </div>
</section>

<section class="space-y-6">
  <div>
    <h2 class="text-foreground mb-4 text-2xl font-semibold">{t.challenges}</h2>
    <p class="text-muted-foreground leading-relaxed">
      {project.data.challenges}
    </p>
  </div>
  <div>
    <h2 class="text-foreground mb-4 text-2xl font-semibold">
      {t.key_learnings}
    </h2>
    <p class="text-muted-foreground leading-relaxed">
      {project.data.learnings}
    </p>
  </div>
</section>
